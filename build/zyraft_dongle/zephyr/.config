CONFIG_ZMK_BOOTMODE_BOOTLOADER_MAGIC_VALUE=0x57

#
# Initialization Priorities
#
CONFIG_ZMK_USB_INIT_PRIORITY=96
CONFIG_ZMK_USB_HID_INIT_PRIORITY=95
CONFIG_ZMK_BLE_INIT_PRIORITY=50
# end of Initialization Priorities

CONFIG_ZMK_PHYSICAL_LAYOUT_KEY_ROTATION=y
CONFIG_ZMK_KSCAN=y
