
#
# ZMK
#
CONFIG_ZMK_BOARD_COMPAT=y

#
# Basic Keyboard Setup
#
CONFIG_ZMK_KEYBOARD_NAME="Zyra FT DGL"
CONFIG_USB_DEVICE_PRODUCT="Zyra FT DGL"
CONFIG_BT_DEVICE_NAME="Zyra FT DGL"
CONFIG_USB_DEVICE_VID=0x1D50
CONFIG_USB_DEVICE_PID=0x615E
CONFIG_USB_DEVICE_MANUFACTURER="ZMK Project"
CONFIG_BT_DIS_PNP_VID=0x1D50
CONFIG_BT_DIS_PNP_PID=0x615E
CONFIG_BT_DIS_MODEL_NUMBER_STR="Zyra FT DGL"
CONFIG_BT_DIS_MANUF_NAME_STR="ZMK Project"
CONFIG_NRF_STORE_REBOOT_TYPE_GPREGRET=y

#
# HID
#
CONFIG_ZMK_HID_REPORT_TYPE_HKRO=y
# CONFIG_ZMK_HID_REPORT_TYPE_NKRO is not set
CONFIG_ZMK_HID_KEYBOARD_REPORT_SIZE=6
CONFIG_ZMK_HID_CONSUMER_REPORT_SIZE=6
CONFIG_ZMK_HID_CONSUMER_REPORT_USAGES_FULL=y
# CONFIG_ZMK_HID_CONSUMER_REPORT_USAGES_BASIC is not set
# CONFIG_ZMK_HID_INDICATORS is not set
# CONFIG_ZMK_HID_SEPARATE_MOD_RELEASE_REPORT is not set

#
# Output Types
#
CONFIG_ZMK_USB=y
# CONFIG_ZMK_USB_BOOT is not set
# CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT is not set
CONFIG_USB_NUMOF_EP_WRITE_RETRIES=10
CONFIG_USB_HID_POLL_INTERVAL_MS=1
CONFIG_ZMK_BLE=y
# CONFIG_ZMK_BLE_EXPERIMENTAL_CONN is not set
# CONFIG_ZMK_BLE_EXPERIMENTAL_SEC is not set
# CONFIG_ZMK_BLE_EXPERIMENTAL_FEATURES is not set
CONFIG_ZMK_BLE_PASSKEY_ENTRY=y
# CONFIG_BT_SMP_ALLOW_UNAUTH_OVERWRITE is not set
CONFIG_BT_CTLR_PHY_2M=y
CONFIG_ZMK_BLE_THREAD_STACK_SIZE=768
CONFIG_ZMK_BLE_THREAD_PRIORITY=5
CONFIG_ZMK_BLE_KEYBOARD_REPORT_QUEUE_SIZE=20
CONFIG_ZMK_BLE_CONSUMER_REPORT_QUEUE_SIZE=5
CONFIG_ZMK_BLE_MOUSE_REPORT_QUEUE_SIZE=20
# CONFIG_ZMK_BLE_CLEAR_BONDS_ON_START is not set
# CONFIG_BT_GATT_NOTIFY_MULTIPLE is not set
CONFIG_BT_GATT_AUTO_SEC_REQ=y
CONFIG_BT_PERIPHERAL_PREF_MIN_INT=6
CONFIG_BT_PERIPHERAL_PREF_MAX_INT=12
CONFIG_BT_PERIPHERAL_PREF_LATENCY=30
CONFIG_BT_PERIPHERAL_PREF_TIMEOUT=400
CONFIG_BT_DEVICE_NAME_MAX=16
# end of Output Types
# end of HID

CONFIG_ZMK_SPLIT=y
CONFIG_ZMK_SPLIT_ROLE_CENTRAL=y
CONFIG_ZMK_SPLIT_BLE=y

#
# BLE Transport
#
CONFIG_ZMK_SPLIT_BLE_PRIORITY=1
CONFIG_BT_ATT_TX_COUNT=10
CONFIG_ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS=2
CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING=y
CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_QUEUE_SIZE=2
CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_PROXY=y
CONFIG_ZMK_SPLIT_BLE_CENTRAL_POSITION_QUEUE_SIZE=5
CONFIG_ZMK_SPLIT_BLE_CENTRAL_SPLIT_RUN_STACK_SIZE=512
CONFIG_ZMK_SPLIT_BLE_CENTRAL_SPLIT_RUN_QUEUE_SIZE=5
CONFIG_ZMK_SPLIT_BLE_PREF_INT=6
CONFIG_ZMK_SPLIT_BLE_PREF_LATENCY=30
CONFIG_ZMK_SPLIT_BLE_PREF_TIMEOUT=400
CONFIG_BT_MAX_PAIRED=7
CONFIG_BT_MAX_CONN=7
CONFIG_BT_GAP_AUTO_UPDATE_CONN_PARAMS=y
# end of BLE Transport
# end of Basic Keyboard Setup

#
# Keymaps
#
CONFIG_ZMK_KEYMAP_LAYER_REORDERING=y
CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE=y
CONFIG_ZMK_KEYMAP_LAYER_NAME_MAX_LEN=20
# end of Keymaps

CONFIG_ZMK_STUDIO=y
CONFIG_ZMK_STUDIO_LOCKING=y
CONFIG_ZMK_STUDIO_LOCK_IDLE_TIMEOUT_SEC=600
CONFIG_ZMK_STUDIO_LOCK_ON_DISCONNECT=y
CONFIG_ZMK_STUDIO_RPC=y

#
# Transports
#
CONFIG_ZMK_STUDIO_TRANSPORT_UART=y
CONFIG_ZMK_STUDIO_TRANSPORT_BLE=y
CONFIG_BT_CONN_TX_MAX=64
CONFIG_ZMK_STUDIO_TRANSPORT_BLE_PREF_LATENCY=10
# end of Transports

CONFIG_ZMK_STUDIO_RPC_THREAD_STACK_SIZE=4096
CONFIG_ZMK_STUDIO_RPC_RX_BUF_SIZE=30
CONFIG_ZMK_STUDIO_RPC_TX_BUF_SIZE=64

#
# Display/LED Options
