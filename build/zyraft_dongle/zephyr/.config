CONFIG_ZMK_BEHAVIOR_HOLD_TAP=y
CONFIG_ZMK_BEHAVIOR_HOLD_TAP_MAX_HELD=10
CONFIG_ZMK_BEHAVIOR_HOLD_TAP_MAX_CAPTURED_EVENTS=40
CONFIG_ZMK_BEHAVIOR_KEY_TOGGLE=y
CONFIG_ZMK_BEHAVIOR_MOUSE_KEY_PRESS=y
CONFIG_ZMK_BEHAVIOR_STICKY_KEY=y
CONFIG_ZMK_BEHAVIOR_STICKY_KEY_MAX_HELD=10
CONFIG_ZMK_BEHAVIOR_TAP_DANCE=y
CONFIG_ZMK_BEHAVIOR_TAP_DANCE_MAX_HELD=10
CONFIG_ZMK_BEHAVIOR_INPUT_TWO_AXIS=y
CONFIG_ZMK_BEHAVIOR_STUDIO_UNLOCK=y
CONFIG_ZMK_BEHAVIOR_MACRO=y
CONFIG_ZMK_MACRO_DEFAULT_WAIT_MS=15
CONFIG_ZMK_MACRO_DEFAULT_TAP_MS=30
