#
# Pointing Options
#
# CONFIG_ZMK_MOUSE is not set
CONFIG_ZMK_POINTING=y
CONFIG_INPUT_THREAD_STACK_SIZE=1024
# CONFIG_ZMK_POINTING_SMOOTH_SCROLLING is not set
CONFIG_ZMK_INPUT_LISTENER=y
CONFIG_ZMK_INPUT_PROCESSOR_SCALER=y
CONFIG_ZMK_INPUT_PROCESSOR_BEHAVIORS=y
# end of Pointing Options

#
# Power Management
#
CONFIG_ZMK_BATTERY_REPORTING=y
CONFIG_ZMK_BATTERY_REPORTING_FETCH_MODE_STATE_OF_CHARGE=y
# CONFIG_ZMK_BATTERY_REPORTING_FETCH_MODE_LITHIUM_VOLTAGE is not set
CONFIG_ZMK_IDLE_TIMEOUT=30000
# CONFIG_ZMK_SLEEP is not set
CONFIG_PM_DEVICE=y
CONFIG_ZMK_EXT_POWER=y
# CONFIG_ZMK_PM_SOFT_OFF is not set
# end of Power Management

#
# Combo options
#
CONFIG_ZMK_COMBO_MAX_PRESSED_COMBOS=4
CONFIG_ZMK_COMBO_MAX_COMBOS_PER_KEY=0
CONFIG_ZMK_COMBO_MAX_KEYS_PER_COMBO=0
# end of Combo options

#
# Behavior Options
#
CONFIG_ZMK_BEHAVIORS_QUEUE_SIZE=64
CONFIG_ZMK_BEHAVIOR_METADATA=y
CONFIG_ZMK_BEHAVIOR_LOCAL_IDS=y
CONFIG_ZMK_BEHAVIOR_LOCAL_IDS_IN_BINDINGS=y
CONFIG_ZMK_BEHAVIOR_LOCAL_ID_TYPE_SETTINGS_TABLE=y
