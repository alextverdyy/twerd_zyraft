&pinctrl {
    uart0_default: uart0_default {
        group1 {
            psels = <((((((0) * 32U) + (8)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>;
            bias-pull-up;
        };
        group2 {
            psels = <((((((0) * 32U) + (6)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <((((((0) * 32U) + (8)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (6)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };

    i2c0_default: i2c0_default {
        group1 {
            psels = <((((((0) * 32U) + (17)) & 0x1FFU) << 0U) | ((12U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (20)) & 0x1FFU) << 0U) | ((11U & 0xFFU) << 24U))>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <((((((0) * 32U) + (17)) & 0x1FFU) << 0U) | ((12U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (20)) & 0x1FFU) << 0U) | ((11U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };

    spi1_default: spi1_default {
        group1 {
            psels = <((((((1) * 32U) + (13)) & 0x1FFU) << 0U) | ((4U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (10)) & 0x1FFU) << 0U) | ((5U & 0xFFU) << 24U))>,
                <((((((1) * 32U) + (11)) & 0x1FFU) << 0U) | ((6U & 0xFFU) << 24U))>;
        };
    };

    spi1_sleep: spi1_sleep {
        group1 {
            psels = <((((((1) * 32U) + (13)) & 0x1FFU) << 0U) | ((4U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (10)) & 0x1FFU) << 0U) | ((5U & 0xFFU) << 24U))>,
                <((((((1) * 32U) + (11)) & 0x1FFU) << 0U) | ((6U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };
};
