ZMK_BASE_LAYER(Sym,
// ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
//label= "SYM"                               ;
// ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
//             │      {      │      &      │      *      │      (      │      }      │   │      6      │      7      │      8      │      9      │      0      │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │      '      │      $      │      %      │      ^      │      +      │   │      "      │      ?      │      '      │      -      │      *      │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │     ___     │      ~      │      !      │      @      │      #      │   │      |      │      _      │      !      │      "      │      +      │
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
//                                                       │     ___     │      (      │   │      }      │      /      │
//                                                       ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                &kp LBRC      &kp AMPS      &kp STAR      &kp LPAR      &kp RBRC        , &kp N6        &kp N7        &kp N8        &kp N9        &kp N0        ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &kp SQT       &kp DLLR      &kp PERCENT   &kp CARET     &kp PLUS        , &kp DQT       &kp QMARK     &kp SQT       &kp MINUS     &kp ASTRK     ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                ___           &kp TILDE     &kp EXCL      &kp AT        &kp HASH        , &kp PIPE      &kp UNDER     &kp EXCL      &kp DQT       &kp PLUS      ,
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
                                                      ___           &kp LPAR        , &kp RBRC      &kp FSLH
//                                                      ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
)

