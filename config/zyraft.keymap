#define CONFIG_WIRELESS

// Suppress base.keymap's 38-key layer definitions (zyraft is 34 keys).
#define ZMK_BASE_LAYER(name, ...)

#include <zmk-helpers/key-labels/34.h>

// 34.h defines THUMBS as THUMBS_L THUMBS_R (LH0 LH1 RH0 RH1). For this 34-key
// layout we want LH1 LH0 RH0 RH1 in hold-trigger-key-positions. Undefine first
// to avoid redefinition warning, then redefine.
#undef THUMBS
#define THUMBS LH1 LH0 RH0 RH1

#include <dt-bindings/zmk/oskey.h>
#include <behaviors/oskey.dtsi>

#include "base.keymap"

// BT + OS combo macros: select BT profile and set OS in one press.
ZMK_MACRO(bt_win, bindings = <&bt BT_SEL 0>, <&os_sel OS_WIN>; wait-ms = <10>; tap-ms = <5>;)
ZMK_MACRO(bt_mac, bindings = <&bt BT_SEL 1>, <&os_sel OS_MAC>; wait-ms = <10>; tap-ms = <5>;)
ZMK_MACRO(bt_lin, bindings = <&bt BT_SEL 2>, <&os_sel OS_LIN>; wait-ms = <10>; tap-ms = <5>;)

// OS-aware app-switcher modifier (Alt on Win/Lin, Cmd on Mac).
/ {
    behaviors {
        ok_swp_mod: os_key_swapper_mod {
            compatible = "zmk,behavior-os-key";
            #binding-cells = <0>;
            bindings = <&kt LALT>, <&kt LGUI>, <&kt LALT>;
        };
    };
};

ZMK_TRI_STATE(swapper, bindings = <&ok_swp_mod>, <&kp TAB>, <&ok_swp_mod>;
    ignored-key-positions = <LT2 RT2 RM1 RM2 RM3>;)

// Tap: sticky sym-layer | Hold: sym-layer.
ZMK_HOLD_TAP(magic_sym, bindings = <&mo>, <&sl>; flavor = "balanced";
             tapping-term-ms = <200>; quick-tap-ms = <QUICK_TAP_MS>;)

// Zyraft-specific extra combo: MAGIC_SYM shifted to RT3+RT4 (no thumb key for SYM on 34 keys).
/ {
    combos {
        combo_magic_sym {
            timeout-ms = <COMBO_TERM_FAST>;
            key-positions = <RT3 RT4>;
            bindings = <&magic_sym SYM SYM>;
            layers = <DEF>;
        };
    };
};

/* Keymap */

#undef ZMK_BASE_LAYER
#define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)                                 \
    ZMK_LAYER(name, LT RT LM RM LB RB LH RH)

// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

ZMK_BASE_LAYER(Base,
// ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
//label= "BASE"                              ;
// ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
//             │      Q      │      W      │      E      │      R      │      T      │   │      Y      │      U      │      I      │      O      │      P      │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │  LCTRL A    │   LALT S    │   LGUI D    │  LSHFT F    │      G      │   │      H      │  RSHFT J    │   RGUI K    │   RALT L    │  RCTRL ;    │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │      Z      │      X      │      C      │      V      │      B      │   │     N/Ñ     │      M      │  , morph    │  . morph    │    q! morph │
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
//                                                       │ MAGIC SHIFT │  SPACE/NAV  │   │   RET/FN    │  BSPC/NUM   │
//                                                       ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                &kp Q         &kp W         &kp E         &kp R         &kp T           , &kp Y         &kp U         &kp I         &kp O         &kp P         ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &hml LCTRL A  &hml LALT S   &hml LGUI D   &hml LSHFT F  &kp G           ,                 &kp H         &hmr RSHFT J  &hmr LGUI K   &hmr RALT L   &hmr RCTRL SEMI,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &kp Z         &kp X         &kp C         &kp V         &kp B           , &kp N         &kp M         &comma_morph  &dot_morph    &qexcl         ,
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
                                                        MAGIC_SHIFT   &lt_spc NAV 0      , &lt FN RET    &lt NUM BSPC
//                                                      ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
)
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

ZMK_BASE_LAYER(Nav,
// ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
//label= "NAV"                               ;
// ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
//             │   LA(F4)    │     ___     │  LS(TAB)    │   Swapper   │     ___     │   │   PG_UP     │  NAV_BSPC   │   NAV_UP    │   NAV_DEL   │     ___     │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │    LGUI     │    LALT     │    LSHFT    │    LCTRL    │     ___     │   │   PG_DN     │  NAV_LEFT   │  NAV_DOWN   │  NAV_RIGHT  │     RET     │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │  ok_undo    │  ok_redo    │     ___     │     ___     │     ___     │   │     INS     │     TAB     │     ___     │     ___     │     ___     │
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
//                                                       │     ___     │     ___     │   │     ___     │   CANCEL    │
//                                                       ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                &kp LA(F4)    ___           &kp LS(TAB)   &swapper      ___             , &kp PG_UP     NAV_BSPC      NAV_UP        NAV_DEL       ___           ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &sk LGUI      &sk LALT      &sk LSHFT     &sk LCTRL     ___             , &kp PG_DN     NAV_LEFT      NAV_DOWN      NAV_RIGHT     &kp RET       ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &ok_undo      &ok_redo      ___           ___           ___             , &kp INS       &kp TAB       ___           ___           ___           ,
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
                                                       ___           ___             , ___               CANCEL
//                                                      ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
)
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

ZMK_BASE_LAYER(Fn,
// ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
//label= "FN"                                ;
// ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
//             │     F12     │     F7      │     F8      │     F9      │     ___     │   │     ___     │   C_PREV    │  C_VOL_UP   │   C_NEXT    │     ___     │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │  LGUI F11   │  LALT F4    │  LSHFT F5   │  LCTRL F6   │     ___     │   │     ___     │  DSK_PREV   │  VOL_DOWN   │  DSK_NEXT   │     ___     │
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
//             │     F10     │     F1      │     F2      │     F3      │     ___     │   │   PIN_APP   │   PIN_WIN   │   DSK_MGR   │     ___     │     ___     │
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
//                                                       │     ___     │     ___     │   │   C_MUTE    │    C_PP     │
//                                                       ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
//             ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
                &kp F12       &kp F7        &kp F8        &kp F9        ___             , ___           &kp C_PREV    &kp C_VOL_UP  &kp C_NEXT    ___           ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &hml LGUI F11 &hml LALT F4  &hml LSHFT F5 &hml LCTRL F6 ___             , ___           DSK_PREV      VOL_DOWN      DSK_NEXT      ___           ,
//             ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
                &kp F10       &kp F1        &kp F2        &kp F3        ___             , PIN_APP       PIN_WIN       DSK_MGR       ___           ___           ,
//             ╰─────────────┴─────────────┴─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┴─────────────┴───────────╯
                                                      ___           ___             , &kp C_MUTE    &kp C_PP
//                                                      ╰─────────────┴─────────────╯   ╰─────────────┴─────────────╯
)
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

ZMK_BASE_LAYER(Num,
// ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
